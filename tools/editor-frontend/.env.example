# Farm Editor — front-end environment flags.
# Copy to `.env.local` (gitignored) to override.

# Transport selection. Unset/false (default) = real HTTP transport against the
# headless Tool server (me_toolserver) via the Vite dev proxy (/api → :8080).
# Set to "true" to use the in-memory mock engine instead (offline UI work, no
# server required).
VITE_USE_MOCK=false
